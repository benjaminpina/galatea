# ==============================================================================
# ROOT .GITIGNORE FILE - GALATEA SIMULATION SUITE
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. OS & DEVELOPMENT TOOLS
# ------------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.fuse_hidden*
.directory
.trash/

# IDEs and Code Editors (VS Code, Windsurf, GoLand)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# ------------------------------------------------------------------------------
# 2. COMPONENT A: THE ARCHITECT (FLUTTER DESKTOP)
# ------------------------------------------------------------------------------
# Ephemeral and native build folders
sim_editor_flutter/.dart_tool/
sim_editor_flutter/build/
sim_editor_flutter/.flutter-plugins
sim_editor_flutter/.flutter-plugins-dependencies
sim_editor_flutter/.packages

# Local configuration and signing files
sim_editor_flutter/linux/flutter/ephemeral/
sim_editor_flutter/windows/flutter/ephemeral/
sim_editor_flutter/macos/Flutter/ephemeral/
sim_editor_flutter/**/*.secret
sim_editor_flutter/**/generated_plugin_registrant.dart

# ------------------------------------------------------------------------------
# 3. COMPONENTS B & C: THE FACTORY & THE MONITOR (GO / GOLANG)
# ------------------------------------------------------------------------------
# Compiled binaries and root executables
*.exe
*.exe~
*.dll
*.so
*.dylib
sim_engine_go/cmd/sim_cli/sim_cli
sim_engine_go/cmd/sim_gui/sim_gui

# Test files and profiling (pprof)
*.test
*.out
*.prof
sim_engine_go/cpu.prof
sim_engine_go/mem.prof

# Environment variables and local dependencies
sim_engine_go/.env
sim_engine_go/go.work
sim_engine_go/go.work.sum

# ------------------------------------------------------------------------------
# 4. LEGACY PROJECT (LAZARUS / FREE PASCAL)
# ------------------------------------------------------------------------------
# Exclude heavy binaries and temporary legacy code files
galatea_legacy_pascal/**/*.o
galatea_legacy_pascal/**/*.ppu
galatea_legacy_pascal/**/*.a
galatea_legacy_pascal/**/*.compiled
galatea_legacy_pascal/**/*.bak

# Automatic build output directories
galatea_legacy_pascal/**/lib/
galatea_legacy_pascal/**/backup/

# Lazarus IDE personal session files (do not affect source code)
galatea_legacy_pascal/**/*.lps

# ------------------------------------------------------------------------------
# 5. WORKSPACES (SIMULATION PROJECT DATABASES)
# ------------------------------------------------------------------------------
# Ignore all .db files in workspaces (user data, not tracked)
workspaces/*.db
workspaces/*.db-wal
workspaces/*.db-shm

# Ignore compiled binaries in engine_go
engine_go/bin/


# Demo workspace generated by CLI demo
engine_go/demo_workspace/

# Workspaces databases
*.db